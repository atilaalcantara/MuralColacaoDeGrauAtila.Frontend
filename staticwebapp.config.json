{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "*.css",
      "*.js",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.svg",
      "*.ico",
      "*.woff",
      "*.woff2"
    ]
  },
  "mimeTypes": {
    ".js": "text/javascript",
    ".css": "text/css",
    ".html": "text/html"
  },
  "globalHeaders": {
    "Cache-Control": "public, max-age=3600"
  },
  "routes": [
    {
      "route": "/",
      "rewrite": "/index.html"
    }
  ]
}
